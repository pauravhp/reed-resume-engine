%--- Custom commands ---

\newcommand{\resumeItem}[1]{
  \item\small{
    {#1 \vspace{-2pt}}
  }
}

\newcommand{\resumeSubheading}[4]{
  \vspace{-2pt}\item
    \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-7pt}
}

\newcommand{\resumeProjectHeading}[2]{
    \item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \small#1 & #2 \\
    \end{tabular*}\vspace{-7pt}
}

\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}

%-------------------------------------------
\begin{document}
{% endraw %}

%-----------HEADER-----------
\begin{center}
    {\Huge \scshape Paurav H Param} \\ \vspace{1pt}
    \faPhone\ {{ phone | latex_escape }} ~
    \faEnvelope\ \href{mailto:{{ email | latex_escape }}}{\underline{ {{- email | latex_escape -}} }} ~
    \faLinkedin\ \href{ {{- linkedin_url | latex_escape -}} }{\underline{ {{- linkedin_url | latex_escape -}} }} ~
    \faGithub\ \href{ {{- github_url | latex_escape -}} }{\underline{ {{- github_url | latex_escape -}} }}
\end{center}

%-----------SUMMARY-----------
\section{Summary}
\small{ {{- summary | latex_escape -}} }

%-----------EDUCATION-----------
\section{Education}
  \resumeSubHeadingListStart
    {% for edu in education_list %}
    \resumeSubheading
      { {{- edu.institution | latex_escape -}} }{ {{- edu.start_date | latex_escape -}} -- {{ edu.end_date | latex_escape if edu.end_date else 'Present' }}}
      { {{- edu.degree | latex_escape -}}{% if edu.field_of_study %} in {{ edu.field_of_study | latex_escape }}{% endif %} }{ {{- (edu.location or '') | latex_escape -}} }
    {% if loop.first and include_coursework and coursework_items %}
    \resumeItemListStart
      {% for item in coursework_items %}
      \resumeItem{ {{- item | latex_escape -}} }
      {% endfor %}
    \resumeItemListEnd
    {% endif %}
    {% endfor %}
  \resumeSubHeadingListEnd

%-----------EXPERIENCE-----------
\section{Experience}
  \resumeSubHeadingListStart
    {% for exp in selected_experiences %}
    \resumeSubheading
      { {{- exp.company | latex_escape -}} }{ {{- exp.start_date | latex_escape -}} -- {{ exp.end_date | latex_escape if exp.end_date else 'Present' }}}
      { {{- exp.role_title | latex_escape -}} }{ {{- (exp.location or '') | latex_escape -}} }
      \resumeItemListStart
        {% for bullet in exp.bullets %}
        \resumeItem{ {{- bullet | latex_escape -}} }
        {% endfor %}
      \resumeItemListEnd
    {% endfor %}
  \resumeSubHeadingListEnd

%-----------PROJECTS-----------
\section{Projects}
    \resumeSubHeadingListStart
      {% for proj in selected_projects %}
      \resumeProjectHeading
          {\textbf{ {{- proj.name | latex_escape -}} } $|$ \emph{ {{- (proj.tech_stack or '') | latex_escape -}} }}{}
          \resumeItemListStart
            {% for bullet in proj.bullets %}
            \resumeItem{ {{- bullet | latex_escape -}} }
            {% endfor %}
          \resumeItemListEnd
      {% endfor %}
    \resumeSubHeadingListEnd

%-----------TECHNICAL SKILLS-----------
\section{Technical Skills}
 \begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
     \textbf{Languages}{: {{ skills_languages | latex_escape }} } \\
     \textbf{Frameworks \& Libraries}{: {{ skills_frameworks | latex_escape }} } \\
     \textbf{Tools \& Platforms}{: {{ skills_tools | latex_escape }} }
    }}
 \end{itemize}

{% if leadership %}
%-----------LEADERSHIP / EXTRACURRICULAR-----------
\section{Leadership / Extracurricular}
  \resumeSubHeadingListStart
    {% for entry in leadership %}
    \resumeSubheading
      { {{- entry.organization | latex_escape -}} }{ {{- entry.start_date | latex_escape -}} -- {{ entry.end_date | latex_escape if entry.end_date else 'Present' }}}
      { {{- entry.role | latex_escape -}} }{ {{- (entry.location or '') | latex_escape -}} }
    {% if entry.bullets %}
    \resumeItemListStart
      {% for bullet in entry.bullets %}
      \resumeItem{ {{- bullet | latex_escape -}} }
      {% endfor %}
    \resumeItemListEnd
    {% endif %}
    {% endfor %}
  \resumeSubHeadingListEnd
{% endif %}

%-------------------------------------------
\end{document}
